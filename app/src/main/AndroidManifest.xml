<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="com.google.android.gms.permission.AD_ID" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- OCR/Scanner এর জন্য ক্যামেরা পারমিশন -->
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- [FIX] Play Store Policy & Higher Version Fix for Images -->
    <!-- Android 12 বা তার নিচের জন্য -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- Android 13 এবং তার উপরের জন্য (নতুন পলিসি অনুযায়ী) -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <!-- [IMPORTANT] নিশ্চিত করুন এখানে কোনো READ_CONTACTS পারমিশন নেই (গুগল এটি নিষিদ্ধ করেছে) -->

    <application
        android:allowBackup="true"
        android:hardwareAccelerated="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.BanglaOxford3000Vocabulary">

        <activity
            android:name=".IeltsActivity"
            android:exported="false" />
        <activity
            android:name=".QRCodeScanner"
            android:exported="false" />
        <activity
            android:name=".TextScannerActivity"
            android:exported="false" />
        <activity
            android:name=".FirstActivity"
            android:exported="false" />

        <!-- [FIX] AdMob App ID (Caret position fixed here) -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-3940256099942544~3347511713" />




        <activity
            android:name=".TextToSpeechActivity"
            android:exported="false" />

        <activity
            android:name=".MainActivityPdfShower"
            android:exported="false"
            android:theme="@style/Theme.PdfView.SelectedTheme" />

        <activity
            android:name=".ButtonActivity"
            android:exported="false" />

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".PortraitCaptureActivity"
            android:resizeableActivity="true"
            android:theme="@style/zxing_CaptureTheme"
            tools:ignore="LockedOrientationActivity" />

    </application>

</manifest>